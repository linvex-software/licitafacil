// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Entidade Empresa (Tenant)
model Empresa {
  id        String    @id @default(uuid())
  name      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? // Soft delete: quando não null, registro está deletado

  // Relacionamento: Uma empresa tem muitos usuários
  users              User[]
  // Relacionamento: Uma empresa tem muitas licitações
  bids               Bid[]
  // Relacionamento: Uma empresa tem muitos logs de auditoria
  auditLogs          AuditLog[]
  // Relacionamento: Uma empresa tem muitos documentos
  documents          Document[]
  // Relacionamento: Uma empresa tem muitas versões de documentos
  documentVersions   DocumentVersion[]
  // Relacionamento: Uma empresa tem muitos templates de checklist
  checklistTemplates ChecklistTemplate[]
  // Relacionamento: Uma empresa tem muitos itens de checklist
  checklistItems     ChecklistItem[]
  // Relacionamento: Uma empresa tem muitos prazos
  prazos             Prazo[]
  // Relacionamento: Uma empresa tem muitos alertas
  alerts             Alert[]
  // Relacionamento: Uma empresa pode ter uma configuração de cliente (1:1)
  clienteConfig      ClienteConfig?
  // Relacionamento: Uma empresa pode ter um contrato (1:1)
  contrato           Contrato?
  // Relacionamento: Uma empresa tem muitas análises de edital
  editalAnalises     EditalAnalise[]
  // Relacionamento: Uma empresa tem muitas buscas salvas (ComprasNet)
  buscasSalvas       BuscaSalva[]
  // Relacionamento: Uma empresa tem muitas petições jurídicas
  peticoes           Peticao[]
  // Relacionamento: Uma empresa tem muitas simulações de disputa
  simulacoes         SimulacaoDisputa[]
  // Relacionamento: Uma empresa tem muitos históricos de chat com edital
  chatHistoricos     ChatHistorico[]
  // Relacionamento: Uma empresa tem muitas análises preditivas de licitações
  bidPredictions     BidPrediction[]

  @@index([deletedAt]) // Otimizar queries que filtram deletados
  @@map("empresas")
}

// Enum de papéis de usuário
enum UserRole {
  SUPER_ADMIN
  ADMIN
  COLABORADOR
}

// Enums de plano e status do cliente
enum PlanoTipo {
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum ClienteStatus {
  ATIVO
  SUSPENSO
  CANCELADO
  TRIAL
}

// Entidade User (Usuário)
model User {
  id        String    @id @default(uuid())
  email     String    @unique
  password  String
  name      String
  role      UserRole  @default(COLABORADOR)
  empresaId String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? // Soft delete: quando não null, registro está deletado

  // Relacionamento: Um usuário pertence a uma empresa
  empresa                   Empresa             @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  // Relacionamento: Um usuário pode ter vários logs de auditoria
  auditLogs                 AuditLog[]
  // Relacionamento: Um usuário pode fazer upload de vários documentos
  uploadedDocuments         Document[]
  // Relacionamento: Um usuário pode fazer upload de várias versões de documentos
  uploadedDocumentVersions  DocumentVersion[]
  // Relacionamento: Um usuário pode criar vários templates de checklist
  createdChecklistTemplates ChecklistTemplate[]
  // Relacionamento: Um usuário pode concluir vários itens de checklist
  checklistItemsConcluidos  ChecklistItem[]

  // Configurações de notificação por email
  receberEmails       Boolean @default(true)
  receberDocVencendo  Boolean @default(true)
  receberPrazoCritico Boolean @default(true)
  receberRisco        Boolean @default(true)
  frequenciaEmail     String  @default("IMEDIATO") // IMEDIATO | DIARIO | OFF
  unsubscribeToken    String? @unique

  // Reset de senha
  passwordResetToken   String?   @unique
  passwordResetExpires DateTime?

  @@index([email])
  @@index([empresaId])
  @@index([role])
  @@index([deletedAt]) // Otimizar queries que filtram deletados
  @@index([empresaId, deletedAt]) // Índice composto para queries de tenant + soft delete
  @@map("users")
}

// Entidade Bid (Licitação)
model Bid {
  id                   String    @id @default(uuid())
  empresaId            String
  title                String
  agency               String
  uf                   String    @default("NI")
  municipio            String?
  modality             String
  legalStatus          String
  operationalState     String
  janelaIntencaoRecursoTermino DateTime?
  isVencedorProvisorio         Boolean              @default(false)
  statusEsclarecimento         StatusEsclarecimento @default(NORMAL)
  dataAdjudicacao              DateTime?
  dataHomologacao              DateTime?
  riskReason           String? // Motivo do estado EM_RISCO (para alertas e relatórios)
  lastRiskAnalysisAt   DateTime? // Última vez que a análise de risco foi executada
  manualRiskOverride   Boolean   @default(false) // Se o estado foi definido manualmente (override)
  manualRiskOverrideBy String? // Usuário que fez o override manual
  manualRiskOverrideAt DateTime? // Data/hora do override manual
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  deletedAt            DateTime? // Soft delete: quando não null, registro está deletado

  // Campos de alerta por email
  alertaPrazoEnviado   Boolean   @default(false)
  alertaPrazoEnviadoEm DateTime?
  alertaRiscoEnviado   Boolean   @default(false)
  alertaRiscoEnviadoEm DateTime?

  // Relacionamento: Uma licitação pertence a uma empresa
  empresa        Empresa            @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  // Relacionamento: Uma licitação pode ter vários documentos
  documents      Document[]
  // Relacionamento: Uma licitação pode ter vários itens de checklist
  checklistItems ChecklistItem[]
  // Relacionamento: Uma licitação pode ter vários prazos
  prazos         Prazo[]
  // Relacionamento: Uma licitação pode ter várias análises de edital
  editalAnalises EditalAnalise[]
  // Relacionamento: Uma licitação pode ter várias petições jurídicas
  peticoes       Peticao[]
  // Relacionamento: Uma licitação pode ter vários eventos jurídicos
  eventos        EventoLicitacao[]
  // Relacionamento: Uma licitação pode ter várias simulações de disputa
  simulacoes     SimulacaoDisputa[]
  // Relacionamento: Uma licitação pode ter vários históricos de chat com edital
  chatHistoricos ChatHistorico[]
  // Relacionamento: Uma licitação pode ter várias análises preditivas
  bidPredictions BidPrediction[]

  @@index([empresaId])
  @@index([empresaId, operationalState]) // Consultas por empresa e estado operacional
  @@index([createdAt])
  @@index([deletedAt]) // Otimizar queries que filtram deletados
  @@index([empresaId, deletedAt]) // Índice composto para queries de tenant + soft delete
  @@map("bids")
}

// Entidade AuditLog (Log de Auditoria)
// Logs são imutáveis: sem updatedAt, sem deletedAt, sem métodos de update/delete
model AuditLog {
  id           String   @id @default(uuid())
  empresaId    String // Obrigatório: isolamento multi-tenant
  userId       String? // Nullable: ações do sistema não têm usuário
  action       String // Ex: "auth.login", "licitacao.create"
  resourceType String? // Ex: "Licitacao", "Documento", "User"
  resourceId   String? // ID do recurso afetado (se aplicável)
  metadata     Json? // Payload sanitizado (opcional)
  ip           String? // IP do cliente
  userAgent    String? // User agent do cliente
  createdAt    DateTime @default(now()) // Único timestamp (imutável)

  // Relacionamento: Um log pertence a uma empresa
  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  // Relacionamento: Um log pode ter um usuário (nullable)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([empresaId, createdAt(sort: Desc)]) // Consultas por tenant ordenadas por data
  @@index([empresaId, action]) // Consultas por ação
  @@index([empresaId, resourceType, resourceId]) // Consultas por recurso
  @@index([userId]) // Consultas por usuário
  @@map("audit_logs")
}

enum TipoPeticao {
  IMPUGNACAO
  ESCLARECIMENTO
  INTENCAO_RECURSO
  RECURSO
  CONTRA_RAZAO
}

enum StatusPeticao {
  RASCUNHO
  ENVIADO
}

enum EscopoImpugnacao {
  TOTAL
  PARCIAL
}

enum EfeitoRecurso {
  SUSPENSIVO
  DEVOLUTIVO
  NAO_APLICA
}

enum AutorTipo {
  CONCORRENTE
  CIDADAO
  ORGAO
}

enum TipoEventoLicitacao {
  EDITAL_PUBLICADO
  SESSAO_ABERTA
  ESCLARECIMENTO_PUBLICADO
  ADENDO_EMITIDO
  PRAZO_PROPOSTA_REABERTO
  JULGAMENTO_ENCERRADO
  JANELA_RECURSO_ABERTA
  JANELA_RECURSO_ENCERRADA
  INTENCAO_RECURSO_REGISTRADA
  RECURSO_INTERPOSTO
  RECURSO_DECIDIDO
  CONTRA_RAZOES_APRESENTADAS
  SUSPENSA_POR_RECURSO
  SUSPENSAO_ENCERRADA
  HABILITACAO_ANALISADA
  INABILITACAO_REGISTRADA
  ADJUDICACAO
  HOMOLOGACAO
  HOMOLOGACAO_ANULADA
  REVOGACAO
  IMPUGNACAO_RECEBIDA
  IMPUGNACAO_DECIDIDA
}

enum StatusEsclarecimento {
  NORMAL
  ADENDO_EMITIDO
  PRAZO_REABERTO
}

model Peticao {
  id          String        @id @default(cuid())
  empresaId   String
  bidId       String
  tipo        TipoPeticao
  conteudo    String?       @db.Text
  nomeArquivo String?
  dataEnvio   DateTime?
  status      StatusPeticao @default(RASCUNHO)
  escopoImpugnacao EscopoImpugnacao?
  efeitoRecurso    EfeitoRecurso    @default(NAO_APLICA)
  anonimo          Boolean          @default(false)
  autorTipo        AutorTipo        @default(CONCORRENTE)
  motivoIntencao   String?          @db.Text
  itensContestados String?          @db.Text
  codigoAutenticidade String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?

  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  bid     Bid     @relation(fields: [bidId], references: [id], onDelete: Cascade)

  @@index([empresaId, bidId])
  @@index([empresaId, deletedAt])
  @@map("peticoes")
}

model EventoLicitacao {
  id        String               @id @default(uuid())
  bidId     String
  bid       Bid                  @relation(fields: [bidId], references: [id], onDelete: Cascade)
  tipo      TipoEventoLicitacao
  timestamp DateTime             @default(now())
  detalhes  Json?
  criadoPor String?
  createdAt DateTime             @default(now())

  @@index([bidId])
  @@index([timestamp])
  @@map("eventos_licitacao")
}

model SimulacaoDisputa {
  id                 String   @id @default(cuid())
  empresaId          String
  bidId              String?
  valorInicial       Float
  percentualDesconto Float
  numConcorrentes    Int
  lanceSugerido      Float
  lanceMinimo        Float
  lanceAgressivo     Float
  createdAt          DateTime @default(now())

  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  bid     Bid?    @relation(fields: [bidId], references: [id], onDelete: SetNull)

  @@index([empresaId, bidId, createdAt(sort: Desc)])
  @@map("simulacoes_disputa")
}

model ChatHistorico {
  id        String   @id @default(cuid())
  empresaId String
  bidId     String
  pergunta  String   @db.Text
  resposta  String   @db.Text
  createdAt DateTime @default(now())

  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  bid     Bid     @relation(fields: [bidId], references: [id], onDelete: Cascade)

  @@index([empresaId, bidId])
  @@map("chat_historicos")
}

// Enum de Status do Documento
enum DocumentStatus {
  PENDENTE
  ATIVO
}

// Entidade Document (Documento)
model Document {
  id         String    @id @default(uuid())
  empresaId  String // Multi-tenancy: isolamento por empresa
  name       String // Nome original do arquivo
  filename   String // Nome do arquivo no servidor (com extensão)
  mimeType   String // Tipo MIME (ex: application/pdf)
  size       Int // Tamanho em bytes
  category   String // Categoria do documento
  url        String // Caminho relativo do arquivo armazenado
  uploadedBy String // ID do usuário que fez upload
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime? // Soft delete: quando não null, registro está deletado

  status DocumentStatus @default(ATIVO)

  // Campos de alerta de vencimento
  alertaVencimentoEnviado   Boolean   @default(false)
  alertaVencimentoEnviadoEm DateTime?

  // Campos de validade/vencimento
  doesExpire Boolean   @default(false) // Indica se o documento tem validade
  issuedAt   DateTime? // Data de emissão do documento (opcional)
  expiresAt  DateTime? // Data de vencimento do documento (opcional, obrigatório se doesExpire=true)

  // Associação opcional com licitação
  bidId String? // Opcional: associação com licitação específica

  // Relacionamento: Um documento pertence a uma empresa
  empresa                Empresa           @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  // Relacionamento: Um documento foi enviado por um usuário
  uploader               User              @relation(fields: [uploadedBy], references: [id], onDelete: Cascade)
  // Relacionamento: Um documento pode estar associado a uma licitação (opcional)
  bid                    Bid?              @relation(fields: [bidId], references: [id], onDelete: SetNull)
  // Relacionamento: Um documento pode ter várias versões
  versions               DocumentVersion[]
  // Relacionamento: Um documento pode ser evidência de um item de checklist
  checklistItemEvidencia ChecklistItem?

  @@index([empresaId])
  @@index([empresaId, category]) // Consultas por empresa e categoria
  @@index([empresaId, deletedAt]) // Índice composto para queries de tenant + soft delete
  @@index([empresaId, expiresAt]) // Índice composto para consultas de vencimento e dashboard
  @@index([empresaId, bidId]) // Consultas por empresa e licitação
  @@index([uploadedBy])
  @@index([bidId]) // Consultas por licitação
  @@index([createdAt])
  @@index([deletedAt]) // Otimizar queries que filtram deletados
  @@map("documents")
}

// Entidade DocumentVersion (Versão de Documento)
// Mantém histórico de todas as versões de um documento
model DocumentVersion {
  id            String   @id @default(uuid())
  documentId    String // FK para Document
  empresaId     String // Multi-tenancy: isolamento por empresa
  versionNumber Int // Número da versão (1, 2, 3, ...)
  filename      String // Nome do arquivo no servidor (com extensão)
  mimeType      String // Tipo MIME (ex: application/pdf)
  size          Int // Tamanho em bytes
  url           String // Caminho relativo do arquivo armazenado
  uploadedBy    String // ID do usuário que fez upload desta versão
  isCurrent     Boolean  @default(false) // Indica se é a versão atual
  createdAt     DateTime @default(now()) // Data de criação da versão

  // Relacionamento: Uma versão pertence a um documento
  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  // Relacionamento: Uma versão pertence a uma empresa
  empresa  Empresa  @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  // Relacionamento: Uma versão foi enviada por um usuário
  uploader User     @relation(fields: [uploadedBy], references: [id], onDelete: Cascade)

  @@unique([documentId, versionNumber]) // Garantir que não há versões duplicadas
  @@index([documentId]) // Consultas por documento
  @@index([empresaId]) // Consultas por empresa (multi-tenant)
  @@index([documentId, isCurrent]) // Consultas para encontrar versão atual
  @@index([documentId, versionNumber(sort: Desc)]) // Consultas ordenadas por versão
  @@index([empresaId, documentId]) // Consultas por empresa e documento
  @@index([uploadedBy]) // Consultas por usuário que fez upload
  @@index([createdAt]) // Consultas ordenadas por data
  @@map("document_versions")
}

// Entidade ChecklistTemplate (Template de Checklist)
model ChecklistTemplate {
  id          String    @id @default(uuid())
  empresaId   String // Multi-tenancy: isolamento por empresa
  modality    String // Modalidade da licitação (PREGAO_ELETRONICO, CONCORRENCIA, DISPENSA, OUTRA)
  name        String // Nome do template (ex: "Template Padrão - Pregão Eletrônico")
  description String? // Descrição opcional do template
  items       Json // Array de itens do checklist em JSON
  isActive    Boolean   @default(true) // Se o template está ativo
  isDefault   Boolean   @default(false) // Se é o template padrão para a modalidade
  createdBy   String // ID do usuário que criou o template
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime? // Soft delete: quando não null, registro está deletado

  // Relacionamento: Um template pertence a uma empresa
  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  // Relacionamento: Um template foi criado por um usuário
  creator User    @relation(fields: [createdBy], references: [id], onDelete: Cascade)

  @@index([empresaId])
  @@index([empresaId, modality]) // Consultas por empresa e modalidade
  @@index([empresaId, deletedAt]) // Índice composto para queries de tenant + soft delete
  @@index([empresaId, modality, isActive]) // Consultas por empresa, modalidade e status ativo
  @@index([empresaId, modality, isDefault]) // Consultas por empresa, modalidade e padrão
  @@index([createdBy])
  @@index([deletedAt]) // Otimizar queries que filtram deletados
  @@map("checklist_templates")
}

// Entidade ChecklistItem (Item de Checklist de Licitação)
// Representa uma tarefa específica do checklist de uma licitação
model ChecklistItem {
  id             String    @id @default(uuid())
  empresaId      String // Multi-tenancy: isolamento por empresa
  licitacaoId    String // ID da licitação
  titulo         String // Título do item
  descricao      String? // Descrição opcional
  category       String? // Categoria do item (ex: "DOCUMENTACAO", "PRAZO", "TECNICA")
  exigeEvidencia Boolean   @default(false) // Se requer evidência (documento)
  isCritical     Boolean   @default(false) // Se é um item crítico (afeta análise de risco)
  concluido      Boolean   @default(false) // Se foi concluído
  concluidoPor   String? // ID do usuário que concluiu
  concluidoEm    DateTime? // Data/hora da conclusão
  evidenciaId    String?   @unique // ID do documento usado como evidência (exclusivo)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime? // Soft delete: quando não null, registro está deletado

  // Relacionamento: Um item pertence a uma empresa
  empresa          Empresa   @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  // Relacionamento: Um item pertence a uma licitação
  licitacao        Bid       @relation(fields: [licitacaoId], references: [id], onDelete: Cascade)
  // Relacionamento: Um item pode ter sido concluído por um usuário
  concluidoPorUser User?     @relation(fields: [concluidoPor], references: [id], onDelete: SetNull)
  // Relacionamento: Um item pode ter um documento como evidência
  evidencia        Document? @relation(fields: [evidenciaId], references: [id], onDelete: SetNull)

  @@index([empresaId])
  @@index([empresaId, licitacaoId]) // Consultas por empresa e licitação
  @@index([empresaId, licitacaoId, isCritical]) // Consultas por itens críticos de uma licitação
  @@index([empresaId, deletedAt]) // Índice composto para queries de tenant + soft delete
  @@index([licitacaoId]) // Consultas por licitação
  @@index([licitacaoId, concluido]) // Consultas por licitação e status de conclusão
  @@index([concluidoPor]) // Consultas por usuário que concluiu
  @@index([evidenciaId]) // Consultas por evidência
  @@index([deletedAt]) // Otimizar queries que filtram deletados
  @@map("checklist_items")
}

// Entidade Prazo (Prazo da licitação)
model Prazo {
  id        String    @id @default(uuid())
  empresaId String // Multi-tenancy: isolamento por empresa
  bidId     String // Licitação à qual o prazo pertence
  titulo    String // Nome do prazo (ex: "Entrega de propostas", "Abertura")
  dataPrazo DateTime // Data (e hora) do prazo
  descricao String? // Observações opcionais
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? // Soft delete: quando não null, registro está deletado

  // Relacionamento: Um prazo pertence a uma empresa
  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  // Relacionamento: Um prazo pertence a uma licitação
  bid     Bid     @relation(fields: [bidId], references: [id], onDelete: Cascade)

  @@index([empresaId])
  @@index([empresaId, deletedAt]) // Índice composto para queries de tenant + soft delete
  @@index([bidId]) // Consultas por licitação
  @@index([bidId, dataPrazo]) // Consultas por licitação ordenadas por data
  @@index([dataPrazo]) // Consultas por data (alertas, dashboard)
  @@index([deletedAt]) // Otimizar queries que filtram deletados
  @@map("prazos")
}

// Entidade Alert (Central de Alertas)
model Alert {
  id           String    @id @default(uuid())
  empresaId    String // Multi-tenancy
  title        String
  message      String
  type         String? // Ex: DOCUMENT, BID, SYSTEM, RISK
  severity     String // INFO | WARNING | CRITICAL
  resourceType String? // Ex: "Document", "Bid", "Prazo"
  resourceId   String? // ID do recurso relacionado
  metadata     Json? // Payload opcional
  status       String    @default("UNSEEN") // UNSEEN | SEEN | RESOLVED
  createdBy    String? // userId opcional
  seenAt       DateTime?
  resolvedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  // Relacionamento: pertence a uma empresa
  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@index([empresaId, status])
  @@index([empresaId, severity])
  @@index([empresaId, resourceType, resourceId])
  @@index([createdAt])
  @@index([empresaId, deletedAt])
  @@map("alerts")
}

// Entidade ClienteConfig (Configuração de billing/plano do cliente B2B)
// Relação 1:1 com Empresa (tenant)
model ClienteConfig {
  id                   String  @id @default(uuid())
  empresaId            String  @unique // 1:1 com Empresa
  cnpj                 String  @unique
  email                String // Email comercial
  telefone             String?
  responsavelComercial String? // SDR que fechou a venda

  // Plano e Billing
  plano               PlanoTipo     @default(STARTER)
  valorSetup          Decimal       @db.Decimal(10, 2)
  mensalidade         Decimal       @db.Decimal(10, 2)
  dataInicio          DateTime      @default(now())
  dataProximaCobranca DateTime?
  status              ClienteStatus @default(ATIVO)

  // Limites (plano único high-ticket — sem restrições)
  maxUsuarios      Int @default(999999)
  maxStorageGB     Int @default(999999)
  maxLicitacoesMes Int @default(999999)
  maxAnalisesMes   Int @default(999999)

  // Metadata
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? // Soft delete

  // Relacionamento: pertence a uma empresa (tenant)
  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([plano])
  @@index([deletedAt])
  @@index([cnpj])
  @@map("clientes_config")
}

// Enums de contrato e pagamento
enum ContratoStatus {
  TRIAL
  ATIVO
  SUSPENSO
  CANCELADO
}

enum TipoPagamento {
  SETUP
  MENSALIDADE
  EXTRA
}

// Entidade Contrato (Faturamento do cliente B2B)
// Relação 1:1 com Empresa (tenant)
model Contrato {
  id        String  @id @default(cuid())
  empresaId String  @unique
  empresa   Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  planoNome        String // "Starter", "Professional", "Enterprise"
  valorSetup       Decimal @db.Decimal(10, 2)
  valorMensalidade Decimal @db.Decimal(10, 2)

  dataInicio        DateTime @default(now())
  proximoVencimento DateTime

  status      ContratoStatus @default(TRIAL)
  observacoes String?

  pagamentos Pagamento[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([proximoVencimento])
  @@map("contratos")
}

// Entidade Pagamento (Registro de pagamento manual)
model Pagamento {
  id         String   @id @default(cuid())
  contratoId String
  contrato   Contrato @relation(fields: [contratoId], references: [id], onDelete: Cascade)

  tipo  TipoPagamento
  valor Decimal       @db.Decimal(10, 2)

  dataPrevista DateTime
  dataPago     DateTime?

  metodoPagamento String? // "Boleto", "PIX", "TED"
  comprovanteUrl  String?
  observacoes     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([contratoId])
  @@index([dataPrevista])
  @@map("pagamentos")
}

// Entidade BuscaSalva (Buscas salvas do ComprasNet)
model BuscaSalva {
  id              String    @id @default(uuid())
  empresaId       String
  nome            String
  filtros         Json
  ativa           Boolean   @default(true)
  autoImportar    Boolean   @default(false)
  ultimaExecucao  DateTime?
  totalImportadas Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  // Relacionamento: Uma busca salva pertence a uma empresa
  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@index([empresaId, ativa])
  @@index([empresaId, deletedAt])
  @@map("buscas_salvas")
}

// Enum de status da análise de edital
enum AnaliseStatus {
  PROCESSANDO
  CONCLUIDA
  ERRO
}

// Entidade EditalAnalise (Log de análises de edital com IA)
model EditalAnalise {
  id        String @id @default(cuid())
  bidId     String
  empresaId String

  pdfUrl       String? // URL do PDF analisado
  pdfTamanhoMB Float? // Tamanho em MB

  resultado     Json? // JSON retornado pela IA
  tokensUsados  Int? // Total de tokens consumidos
  tempoSegundos Int? // Tempo de processamento

  status       AnaliseStatus @default(PROCESSANDO)
  erroMensagem String?       @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relacionamentos
  bid     Bid     @relation(fields: [bidId], references: [id], onDelete: Cascade)
  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@index([empresaId, createdAt])
  @@index([bidId])
  @@map("edital_analises")
}

// Entidade BidPrediction (Análise Preditiva de Sucesso em Licitações)
model BidPrediction {
  id        String @id @default(cuid())
  bidId     String
  empresaId String

  // Score final (0-100)
  score        Float
  // Recomendação: PARTICIPAR | ANALISAR | DESCARTAR
  recomendacao String

  // Breakdown dos 6 fatores (JSON)
  fatores Json

  // Explicação gerada pela IA
  explicacao String? @db.Text
  // Recomendações acionáveis geradas pela IA
  acoes      Json?

  // Rastreamento de uso da IA
  tokensUsados  Int?
  tempoSegundos Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relacionamentos
  bid     Bid     @relation(fields: [bidId], references: [id], onDelete: Cascade)
  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@index([bidId])
  @@index([empresaId, createdAt(sort: Desc)])
  @@map("bid_predictions")
}

// Entidade DiarioOficial (Registro de fontes e varreduras de Diários Oficiais)
model DiarioOficial {
  id                  String    @id @default(uuid())
  estado              String // UF (ex: "SP", "RJ")
  municipio           String? // Nome do município (nulo se for diário estadual)
  url                 String // URL base ou do portal específico
  ultimaSincronizacao DateTime? // Data e hora da última varredura bem-sucedida pelo Cron
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  deletedAt           DateTime? // Soft delete

  @@index([estado, municipio])
  @@index([deletedAt])
  @@map("diarios_oficiais")
}
