# Database (PostgreSQL)
# Configure a connection string do seu banco de dados PostgreSQL
# 
# Exemplo local:
DATABASE_URL="postgresql://usuario:senha@localhost:5432/licitafacil?schema=public"
#
# Exemplo serviços na nuvem (copie a connection string):
# - Supabase: https://supabase.com
# - ElephantSQL: https://www.elephantsql.com
# - Railway: https://railway.app
# - Neon: https://neon.tech
#
# Formato: postgresql://user:password@host:port/database?schema=public

# Application
PORT=3001
NODE_ENV=development

# JWT Authentication
# Gere uma chave secreta forte (ex: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET="your-secret-key-change-in-production"