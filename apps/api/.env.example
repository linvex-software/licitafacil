# App
NODE_ENV=production
PORT=3001

# Database
DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT
JWT_SECRET=your-super-secret-jwt-key-here

# Frontend
FRONTEND_URL=https://seucliente.limvex.com.br

# OpenAI
OPENAI_API_KEY=sk-...

# Email (SMTP / SendGrid)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@limvex.com.br
SMTP_PASS=your-smtp-password
EMAIL_FROM=noreply@limvex.com.br
EMAIL_FROM_NAME=Limvex Licitação
SENDGRID_API_KEY=SG....

# Configurações de negócio
DOCUMENT_EXPIRING_SOON_DAYS=30
PRAZO_CRITICAL_DAYS_THRESHOLD=3
PRAZO_ENABLE_CHECKLIST_HEURISTIC=true

# Dev only (NÃO usar em produção)
AUTH_DEV_BYPASS=false
AUDIT_FORCE_FAIL=false
