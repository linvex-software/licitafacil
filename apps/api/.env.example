# App
NODE_ENV=production
PORT=3001

# Database
DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT
JWT_SECRET=your-super-secret-jwt-key-here

# Frontend (origem CORS; pode ser lista separada por vírgula). Produção: https://licitacao.limvex.com
FRONTEND_URL=https://licitacao.limvex.com

# OpenAI
OPENAI_API_KEY=sk-...

# Email (Mailtrap / Resend / etc.)
MAILTRAP_API_TOKEN=seu_token_aqui
# Remetente padrão no código: hello@mail.licitacao.limvex.com — configure SPF/DKIM para esse subdomínio no provedor de e-mail.

# Configurações de negócio
DOCUMENT_EXPIRING_SOON_DAYS=30
PRAZO_CRITICAL_DAYS_THRESHOLD=3
PRAZO_ENABLE_CHECKLIST_HEURISTIC=true

# Dev only (NÃO usar em produção)
AUTH_DEV_BYPASS=false
AUDIT_FORCE_FAIL=false

# Criptografia e fila de disputa
ENCRYPTION_KEY=chave-aleatoria-de-32-caracteres-aqui
REDIS_HOST=localhost
REDIS_PORT=6379

DISPUTA_MOCK=true
# DISPUTA_MOCK=false
