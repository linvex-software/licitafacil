# App
NODE_ENV=production
PORT=3001

# Database
DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT
JWT_SECRET=your-super-secret-jwt-key-here

# Frontend (origem CORS; pode ser lista separada por vírgula). Produção: https://licitacao.limvex.com
FRONTEND_URL=https://licitacao.limvex.com

# Asaas (cobrança / checkout) — Railway
# Chave em Integrações > Chaves de API (produção: $aact_prod_...)
ASAAS_API_KEY=
# Produção: false | Sandbox: true | Omitido: usa produção se ASAAS_API_KEY começar com $aact_prod_, senão sandbox
ASAAS_SANDBOX=false
# Mesmo valor do "Token de autenticação" do webhook no painel Asaas (obrigatório no Asaas; enviado no header asaas-access-token)
ASAAS_WEBHOOK_TOKEN=
# URL que você cadastra no Asaas (só referência): https://<SUA-API-PÚBLICA>/api/webhooks/asaas

# OpenAI
OPENAI_API_KEY=sk-...

# Email — Mailtrap Sending em prod: token da Sending API + domínio/remetente validados no painel.
MAILTRAP_API_TOKEN=seu_token_aqui
# Remetente no código: hello@mail.licitacao.limvex.com (autorize no Mailtrap ou troque o sender no mail.service).

# Configurações de negócio
DOCUMENT_EXPIRING_SOON_DAYS=30
PRAZO_CRITICAL_DAYS_THRESHOLD=3
PRAZO_ENABLE_CHECKLIST_HEURISTIC=true

# Dev only (NÃO usar em produção)
AUTH_DEV_BYPASS=false
AUDIT_FORCE_FAIL=false

# Criptografia e fila de disputa
ENCRYPTION_KEY=chave-aleatoria-de-32-caracteres-aqui
# Redis (Bull). Em produção costuma exigir senha → NOAUTH se faltar.
# Railway (e similares): use a variável REDIS_URL do plugin Redis na API (rede privada).
#   Evite REDIS_PUBLIC_URL para tráfego entre serviços na mesma conta.
# Opção A: URL completa (redis://:SENHA@host:6379 ou rediss://... TLS)
# REDIS_URL=redis://localhost:6379
# Opção B: host + porta + senha — nomes com underscore OU os do template Railway:
#   REDIS_HOST / REDISHOST, REDIS_PORT / REDISPORT, REDIS_PASSWORD / REDISPASSWORD, REDIS_USERNAME / REDISUSER
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_USERNAME=

DISPUTA_MOCK=true
# DISPUTA_MOCK=false
