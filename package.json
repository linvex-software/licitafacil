{
  "name": "@licitafacil/root",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "description": "Sistema de Gestão de Licitações - Monorepo",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "clean": "turbo clean && rm -rf node_modules",
    "prisma:generate": "pnpm --filter @licitafacil/api prisma:generate",
    "prisma:migrate": "pnpm --filter @licitafacil/api prisma:migrate",
    "prisma:studio": "pnpm --filter @licitafacil/api prisma:studio",
    "prisma:seed": "pnpm --filter @licitafacil/api prisma:seed"
  },
  "prisma": {
    "schema": "apps/api/prisma/schema.prisma"
  },
  "devDependencies": {
    "turbo": "^2.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  }
}